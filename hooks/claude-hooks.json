{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST http://localhost:9000/hooks/session-start -H 'Content-Type: application/json' -d @- >/dev/null 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST http://localhost:9000/hooks/stop -H 'Content-Type: application/json' -d @- >/dev/null 2>&1 || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST http://localhost:9000/hooks/notification -H 'Content-Type: application/json' -d @- >/dev/null 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST http://localhost:9000/hooks/prompt-submit -H 'Content-Type: application/json' -d @- >/dev/null 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST http://localhost:9000/hooks/session-end -H 'Content-Type: application/json' -d @- >/dev/null 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
